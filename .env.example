# Polygon.io API key
# Free key: https://polygon.io/
POLYGON_KEY=your_api_key_here

# User accounts (comma-separated username:password pairs)
# If omitted, auth is disabled and a single "default" user is used (good for local dev)
USERS=alice:password1,bob:password2

# JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If omitted, a random secret is generated each restart (sessions won't survive restarts)
JWT_SECRET=your_random_64_char_hex_secret_here
